# ── AI モード ──────────────────────────────────────
# ollama  : 完全ローカル処理（Ollama使用）
# groq    : Groq API（クラウド・無料枠あり）
# openai  : OpenAI API（GPT-4o・従量課金）
# gemini  : Google Gemini API（従量課金）
# claude  : Anthropic Claude API（従量課金）
AI_MODE=groq

# ── Groq API キー ───────────────────────────────────
# groqモード、およびクラウドモード全般の文字起こしに使用
# 取得先: https://console.groq.com/keys
GROQ_API_KEY=

# ── OpenAI API キー ─────────────────────────────────
# openaiモード時に使用
# 取得先: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Google Gemini API キー ──────────────────────────
# geminiモード時に使用
# 取得先: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Anthropic Claude API キー ───────────────────────
# claudeモード時に使用
# 取得先: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Ollama モデル ───────────────────────────────────
# ollamaモード時に使用するモデル名（照会室・相談室）
OLLAMA_MODEL=gemma3:27b

# クリーニング・要約専用モデル（未設定時はOLLAMA_MODELを使用）
# 日本語特化モデルを指定することで精度向上が期待できます
# 例: elyza:jp8b
CLEANING_MODEL=elyza:jp8b

# ── 最大録音時間（目安） ────────────────────────────────
# 要約処理のコンテキストサイズを制御します（30/60/90/120分）
# 設定画面のOllamaモデル枠で変更可能です
MAX_RECORDING_MINUTES=60

# ── 録音ソース ──────────────────────────────────────
# mic    : マイク入力（対面会議・会議室向け）
# system : システム音声（オンライン会議向け）
#          Windows: 追加設定不要
#          Mac: BlackHole のインストールが必要
RECORDING_SOURCE=mic
